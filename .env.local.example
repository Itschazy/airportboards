# airlabs.co — реальные данные рейсов
# Зарегистрируйся: https://airlabs.co/register
# Бесплатный план: 1000 запросов/мес
AIRLABS_API_KEY=

# Google AdSense publisher id — full "ca-pub-XXXXXXXXXXXXXXXX".
# BUILD-TIME var (deploy runs `npm run build`), so set it in the GitHub Actions
# build environment/secret AND redeploy. While empty, no AdSense code is emitted
# and /ads.txt returns a placeholder — the live site is unchanged.
# When set: injects the loader <script>, the google-adsense-account verification
# meta tag, and the /ads.txt DIRECT line.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Optional: set to 0 to hide the informational cookie notice (e.g. once Google's
# "Privacy & messaging" CMP is enabled in the AdSense console). Default: shown.
NEXT_PUBLIC_COOKIE_NOTICE=

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID from the GA4 web data stream (Admin → Data streams → your stream).
# PUBLIC — it ships in the page, like the AdSense client id. Leave empty to disable GA
# entirely; the Consent Mode defaults still ship as long as AdSense is configured, because
# they govern the ad tag too.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Share of the airlabs monthly cap reserved for live human page views rather than the
# background warmer. 35 = the agreed 130k warm / 70k visitors split on a 200k plan.
# AIRLABS_HUMAN_RESERVE_PCT=35
# Absolute override, if a fixed number is preferred over a share:
# AIRLABS_HUMAN_RESERVE=70000
# Raise ONLY after the larger airlabs plan is actually purchased:
# AIRLABS_MONTHLY_CAP=195000
